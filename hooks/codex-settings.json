{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.codex/hooks/assistant/session-start.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.codex/hooks/assistant/skill-router.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.codex/hooks/assistant/learning-signals.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.codex/hooks/assistant/workflow-enforcer.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.codex/hooks/assistant/stop-review.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.codex/hooks/assistant/harness-gate.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.codex/hooks/assistant/workflow-guard.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.codex/hooks/assistant/pre-compress.sh"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.codex/hooks/assistant/post-compact.sh"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.codex/hooks/assistant/task-completed.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.codex/hooks/assistant/session-end.sh"
          }
        ]
      }
    ]
  }
}
